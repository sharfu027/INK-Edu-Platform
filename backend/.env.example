# ─────────────────────────────────────────────────
#  Face Auth Backend — Environment Variables
# ─────────────────────────────────────────────────

# App
APP_NAME=Face Auth API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=face_auth_db

# JWT — CHANGE THESE IN PRODUCTION!
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-2024
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Face Recognition
FACE_SIMILARITY_THRESHOLD=0.75
FACE_MODEL=Facenet512
FACE_DETECTOR=opencv
MAX_FACE_IMAGES=4

# Embedding Encryption — CHANGE IN PRODUCTION! Must be 32+ chars.
EMBEDDING_ENCRYPTION_KEY=change-this-to-a-secure-32char-key!

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO

# Vidya AI Integration (Local path to the Vidya-AI folder)
VIDYA_AI_PATH=C:\Users\srake\Downloads\Vidya-AI-main

